generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Product {
  id Int @id @default(autoincrement())

  name        String
  description String
  price       Float

  cartItems CartItem[]
}

model Cart {
  id Int @id @default(autoincrement())

  items CartItem[]
  total Float

  payments Payment[]
}

model CartItem {
  id Int @id @default(autoincrement())

  quantity Int @default(1)

  cartId    Int
  productId Int

  cart    Cart    @relation(fields: [cartId], references: [id])
  product Product @relation(fields: [productId], references: [id])
}

model Payment {
  id Int @id @default(autoincrement())

  amount Float
  method String // card/blik/applepay
  status String // pending/completed/failed

  cartId Int

  cart Cart @relation(fields: [cartId], references: [id])
}
